generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ArticleStatus {
  draft
  published
  archived
}

/// Author entity — shared across articles to avoid denormalization.
model Author {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  designation String    @default("")
  bio         String?
  avatarUrl   String?   @map("avatar_url")
  socialLinks Json?     @map("social_links")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  articles    Article[]

  @@unique([name, designation])
  @@map("authors")
}

/// CMS article row (managed via Prisma Migrate — do not hand-edit SQL for this table).
model Article {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug              String        @unique
  title             String
  titleEn           String?       @map("title_en")
  excerpt           String?
  excerptEn         String?       @map("excerpt_en")
  featuredImage     String?       @map("featured_image")
  sourceUrl         String?       @map("source_url")
  status            ArticleStatus @default(draft)
  category          String
  tags              String[]      @default([])
  authorId          String        @map("author_id") @db.Uuid
  author            Author        @relation(fields: [authorId], references: [id])
  blocks            Json
  toc               Json
  seo               Json?
  // Case-study specific metadata (null for non-case-study articles)
  clientName        String?       @map("client_name")
  clientLocation    String?       @map("client_location")
  clientUrl         String?       @map("client_url")
  aiModels          String[]      @default([]) @map("ai_models")
  mainChallenges    String?       @map("main_challenges")
  relatedArticleIds String[]      @default([]) @map("related_article_ids")
  viewCount         Int           @default(0) @map("view_count")
  publishedAt       DateTime?     @map("published_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  views             ArticleView[]

  @@index([status, category, publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)], map: "articles_created_at_idx")
  @@index([tags], type: Gin, map: "articles_tags_gin_idx")
  @@map("articles")
}

/// Append-only view log for analytics. The hot write path uses this instead of
/// incrementing view_count inline on every page request.
model ArticleView {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId String   @map("article_id") @db.Uuid
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)

  @@index([articleId, viewedAt])
  @@map("article_views")
}

/// Centralized media assets for the admin gallery (Supabase Storage + metadata).
model MediaLibrary {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  filename  String
  url       String   @unique
  size      Int?
  mimeType  String?  @map("mime_type")
  alt       String   @default("")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([filename])
  @@map("media_library")
}

/// UI copy for public + admin base messages (values edited in /admin/translations).
/// Key schema is defined by messages/{en,ja}.json; seed inserts missing keys only.
model Translation {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyPath    String   @map("key_path")
  locale     String
  value      String   @db.Text
  namespace  String
  isOrphaned Boolean  @default(false) @map("is_orphaned")
  updatedBy  String?  @map("updated_by")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([keyPath, locale])
  @@index([locale, namespace])
  @@index([isOrphaned])
  @@map("translations")
}

/// Append-only audit trail for translation value changes (restore from history).
model TranslationHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyPath       String   @map("key_path")
  locale        String
  previousValue String   @map("previous_value") @db.Text
  changedBy     String?  @map("changed_by")
  changedAt     DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  @@index([keyPath, locale, changedAt(sort: Desc)])
  @@map("translation_history")
}
